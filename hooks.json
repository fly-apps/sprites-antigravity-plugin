{
  "sprites-safety-guard": {
    "PreToolUse": [
      {
        "matcher": ".*(destroy_sprite|delete_sprite|checkpoint_restore|restore_checkpoint|delete_checkpoint|policy_network|network_policy|privilege_policy|resource_policy|service_create|service_start|service_update|make_public).*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/config/plugins/sprites-antigravity-plugin/scripts/sprites_hook.py safety",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "sprites-checkpoint-nudge": {
    "PreToolUse": [
      {
        "matcher": ".*exec.*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/config/plugins/sprites-antigravity-plugin/scripts/sprites_hook.py checkpoint",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "sprites-remote-test-routing": {
    "enabled": false,
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/config/plugins/sprites-antigravity-plugin/scripts/sprites_hook.py remote-test",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
